# ===== PineScope AI Bridge (JSON v2.0) — configuracion =====
# Copia este archivo a ".env" (sin .example) y rellena tus valores.
# NUNCA subas el .env real a GitHub (ya esta en .gitignore por convencion).

# Proveedor de IA a usar: anthropic | openai | gemini
AI_PROVIDER=anthropic

# --- Claves de IA (solo necesitas la del proveedor elegido arriba) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Modelos (opcionales; tienen valores por defecto razonables) ---
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# --- Telegram (Bot API) ---
# TELEGRAM_BOT_TOKEN: te lo da @BotFather al crear el bot.
# TELEGRAM_CHAT_ID: tu chat/grupo destino (puedes sacarlo con @userinfobot o @getidsbot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Seguridad del webhook ---
# Secreto compartido: invéntate una cadena larga y dificil.
# DEBE coincidir con el campo "secret" del JSON que emite el Dashboard de PineScope
# (input "secret" del indicador). Tambien se acepta en el header x-webhook-secret
# o como ?secret=... al final de la URL del webhook.
WEBHOOK_SECRET=cambia-esto-por-un-secreto-largo

# --- Servidor ---
PORT=8080

# Timeout para la llamada a la IA, en milisegundos (~45s). NO afecta la respuesta a
# TradingView: el 200 se manda al instante y la IA corre aparte (hilo/async).
AI_TIMEOUT_MS=45000
